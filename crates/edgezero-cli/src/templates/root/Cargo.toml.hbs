[workspace]
members = [
  "crates/{{proj_core}}",
  "crates/{{proj_cli}}",
{{{workspace_members}}}
]
resolver = "2"

[workspace.package]
authors = []
edition = "2024"
license = "Apache-2.0"
publish = false
version = "0.1.0"

[workspace.dependencies]
{{{workspace_dependencies}}}

[profile.release]
debug = 1
codegen-units = 1
lto = "fat"

[workspace.lints.clippy]
# Strict gate matching the EdgeZero workspace. The allow-list below tracks
# the entries the EdgeZero demo legitimately needs -- extend it lazily when
# a real failure surfaces in your generated code.
pedantic = { level = "warn", priority = -1 }
restriction = { level = "deny", priority = -1 }

# Meta -- required when enabling `restriction` as a group.
blanket_clippy_restriction_lints = "allow"

# Documentation -- private items don't need full docs in app code.
missing_docs_in_private_items = "allow"

# Style / formatting -- match idiomatic Rust conventions.
implicit_return = "allow"
question_mark_used = "allow"
single_call_fn = "allow"
separated_literal_suffix = "allow"

# API design -- `exhaustive_structs` fires on the unit struct generated by
# `edgezero_core::app!`.
exhaustive_structs = "allow"

# Imports / paths -- generated binaries are std applications, not no_std libraries.
std_instead_of_alloc = "allow"
std_instead_of_core = "allow"

[workspace.lints.rust]
unsafe_code = "deny"
