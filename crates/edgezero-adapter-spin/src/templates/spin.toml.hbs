spin_manifest_version = 2

[application]
name = "{{proj_spin}}"
version = "0.1.0"

[[trigger.http]]
route = "/..."
component = "{{proj_spin}}"

[component.{{proj_spin}}]
source = "{{target_dir_spin}}/wasm32-wasip2/release/{{proj_spin_underscored}}.wasm"
allowed_outbound_hosts = ["https://*:*"]
# `app_config` is pre-wired here for the commented-out example
# `[stores.config] ids = ["app_config"]` stanza in the generated
# `edgezero.toml`: uncomment it (and the matching `app_config` field
# on your `AppConfig`) to opt in. When opted in, EdgeZero's KV-backed
# config store opens this label at runtime; `edgezero config push
# --adapter spin` writes directly into the SQLite backend declared
# for it in `runtime-config.toml` (or shells `spin cloud key-value
# set` when the manifest's deploy command targets Fermyon Cloud).
# Without `[stores.config]`, this binding is an unused label and is
# safe to delete alongside the matching `[key_value_store.app_config]`
# stanza in `runtime-config.toml`.
key_value_stores = ["app_config"]
[component.{{proj_spin}}.build]
command = "cargo build --target wasm32-wasip2 --release"
watch = ["src/**/*.rs", "Cargo.toml"]
