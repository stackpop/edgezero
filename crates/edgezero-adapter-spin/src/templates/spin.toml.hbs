spin_manifest_version = 2

[application]
name = "{{proj_spin}}"
version = "0.1.0"

[[trigger.http]]
route = "/..."
component = "{{proj_spin}}"

[component.{{proj_spin}}]
source = "{{target_dir_spin}}/wasm32-wasip2/release/{{proj_spin_underscored}}.wasm"
allowed_outbound_hosts = ["https://*:*"]
# `app_config` is the default `[stores.config].ids` declared in the
# generated `edgezero.toml`. EdgeZero's KV-backed config store opens
# this label at runtime; `config push --adapter spin --local` writes
# entries into it via the seed handler.
key_value_stores = ["app_config"]
[component.{{proj_spin}}.build]
command = "cargo build --target wasm32-wasip2 --release"
watch = ["src/**/*.rs", "Cargo.toml"]
